# Runtime
HAL_IMAGE_TAG=latest
HAL_MODE=direct
HAL_NAME=hal-office
HAL_LOG_LEVEL=INFO

# Wake word
WAKEWORD_DISABLED=false
OPENWAKEWORD_MODEL_PATH=models/openwakeword/hey_hal.onnx
OPENWAKEWORD_THRESHOLD=0.5

# Audio backend
AUDIO_BACKEND=pyaudio
AUDIO_INPUT_DEVICE_INDEX=
AUDIO_OUTPUT_DEVICE_INDEX=
AUDIO_INPUT_DEVICE_NAME_HINT=
AUDIO_OUTPUT_DEVICE_NAME_HINT=
WAKE_SAMPLE_RATE=16000
RECORD_SAMPLE_RATE=16000
TTS_SAMPLE_RATE=22050
AUDIO_CHANNELS=1
RECORD_FRAME_SIZE=1024
OUTPUT_WAV_PATH=/tmp/hal_prompt.wav

# Recording / silence detection
SILENCE_RMS_THRESHOLD=25000
SILENCE_DURATION_SECONDS=2.0
MAX_RECORD_SECONDS=15
MIN_RECORD_SECONDS=0.5

# Optional ALSA volume setup
ALSA_CARD_INDEX=
ALSA_SPEAKER_CONTROL=Speaker
ALSA_SPEAKER_VOLUME=100%

# Network timeout shared by service clients
NETWORK_TIMEOUT_SECONDS=30

# Direct backend: Vosk -> Ollama -> Piper
VOSK_URL=ws://10.0.0.10:2700
OLLAMA_URL=http://10.0.0.10:11434/api/generate
OLLAMA_MODEL=llama3:latest
OLLAMA_SYSTEM=Limit your responses to three sentences. You are a voice assistant. Please refrain from providing unnecessary information.
PIPER_URL=http://10.0.0.10:5000

# Home Assistant backend
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
HA_LANGUAGE=en
HA_AGENT_ID=
HA_CONVERSATION_ID=hal-office

# GPIO LEDs
LIGHT_BACKEND=gpio
GPIO_ACTIVE_HIGH=true

# BCM pin numbering; either pin may be blank, but at least one is required for gpio
GPIO_RED_LED_PIN=18
GPIO_WHITE_LED_PIN=23

# PWM behavior
GPIO_ENABLE_PWM=true
GPIO_PWM_FREQUENCY=200
GPIO_IDLE_RED_BRIGHTNESS=0.20
GPIO_ACTIVE_RED_BRIGHTNESS=1.00
GPIO_WHITE_BRIGHTNESS=1.00

# Invert pins when using inverted transistor/driver wiring
GPIO_RED_LED_INVERTED=false
GPIO_WHITE_LED_INVERTED=false
